{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Auraxis Smoke Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Post-deploy smoke test suite. Runs via Newman after each successful deploy to verify key endpoints respond correctly."
  },
  "item": [
    {
      "name": "01 - Health check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('healthz returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('healthz status is ok', function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body.status).to.eql('ok');",
              "});",
              "pm.test('healthz does not return 5xx', function () {",
              "  pm.expect(pm.response.code).to.not.be.within(500, 599);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/healthz",
          "host": ["{{base_url}}"],
          "path": ["healthz"]
        }
      }
    },
    {
      "name": "02 - Auth login (obtain token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('login returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('login does not return 5xx', function () {",
              "  pm.expect(pm.response.code).to.not.be.within(500, 599);",
              "});",
              "var body = pm.response.json();",
              "var token = body && body.data ? body.data.token : null;",
              "pm.test('login returns a JWT token', function () {",
              "  pm.expect(token).to.be.a('string').and.not.empty;",
              "});",
              "pm.collectionVariables.set('token', token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "X-API-Contract", "value": "v2"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"password\": \"{{test_password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": ["{{base_url}}"],
          "path": ["auth", "login"]
        }
      }
    },
