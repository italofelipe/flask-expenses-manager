        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"mutation Login($email: String, $password: String!) { login(email: $email, password: $password) { token message } }\",\n  \"variables\": {\n    \"email\": \"{{runEmail}}\",\n    \"password\": \"{{testPasswordWrong}}\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/graphql",
          "host": [
            "{{baseUrl}}"
